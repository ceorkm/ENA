{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../dist",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "ENA",
    "version": "0.1.0"
  },
  "tauri": {
    "macOSPrivateApi": true,
    "systemTray": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false
    },
    "allowlist": {
      "all": false,
      "globalShortcut": {
        "all": true
      },
      "window": {
        "all": true
      },
      "dialog": {
        "open": true
      },
      "protocol": {
        "asset": true,
        "assetScope": ["$HOME/**", "/**"]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "ENA",
        "width": 700,
        "height": 560,
        "minWidth": 360,
        "minHeight": 180,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": true,
        "skipTaskbar": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": ["app", "dmg"],
      "identifier": "com.ena.promptenhancer",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "category": "DeveloperTool",
      "shortDescription": "Floating prompt enhancer",
      "longDescription": "ENA turns rough thoughts into precise, project-aware prompts."
    }
  }
}
